# Server Configuration
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Database Configuration (Prisma Postgres / PostgreSQL)
# Pooled connection string (used by Prisma Client in serverless functions)
DATABASE_URL="postgresql://username:password@localhost:5432/task_management?schema=public"

# Direct connection string (used for running migrations and direct DB CLI access)
DIRECT_URL="postgresql://username:password@localhost:5432/task_management?schema=public"

# Authentication
# Must be set to a long, secure, random string in production
JWT_SECRET=replace_with_a_long_secure_random_secret_string
JWT_EXPIRES_IN=7d
